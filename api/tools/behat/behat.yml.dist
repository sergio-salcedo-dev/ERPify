# Paths in this file are relative to api/tools/behat/ (cwd when bin/behat runs).
# Contexts are registered here (not in services_test.yaml) so PHPUnit never
# autoloads classes that depend on Behat\Behat\Context\Context (which lives
# only in tools/behat/vendor). FoB's SymfonyExtension turns these into
# autowired services in the Symfony test container.
default:
    # @wip scenarios are skipped by default (legacy Mink-era steps pending
    # migration to SymfonyExtension/KernelBrowser). Override with --tags=@wip
    # at invocation to run them.
    gherkin:
        filters:
            tags: '~@wip'
    suites:
        default:
            paths:
                - '%paths.base%/../../features/backoffice'
                - '%paths.base%/../../features/frontoffice'
            contexts:
                - Erpify\Tests\Behat\Context\HttpRequestContext:
                      baseUrl: '/api/v1'
                      serverPort: 80
                - Erpify\Tests\Behat\Context\JsonContext
                - Erpify\Tests\Behat\Context\FixturesContext
    extensions:
        FriendsOfBehat\SymfonyExtension:
            kernel:
                class: Erpify\Kernel
                environment: test
                debug: true
            bootstrap: '%paths.base%/bootstrap.php'
