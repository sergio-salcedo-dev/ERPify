# Paths in this file are relative to api/tools/behat/ (cwd when bin/behat runs).
#
# Override base URL: export MINK_BASE_URL=... or set in api/.env (Makefile uses http://php in Docker).
default:
    suites:
        default:
            paths:
                - '%paths.base%/../../features/backoffice'
                - '%paths.base%/../../features/frontoffice'
            contexts:
                - Erpify\Tests\Behat\Context\FeatureContext
                - Erpify\Tests\Behat\Context\MediaApiContext
                - Erpify\Tests\Behat\Context\MessengerContext
    extensions:
        Behat\MinkExtension\ServiceContainer\MinkExtension:
            base_url: '%env(MINK_BASE_URL)%'
            sessions:
                default:
                    browserkit_http: ~
