{
    "name": "erpify/behat-tools",
    "description": "Isolated Behat + Mink stack (Behat 3 targets Symfony 7 components; app remains Symfony 8)",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "behat/behat": "^3.31.0",
        "behat/mink": "^1.13.0",
        "behat/mink-browserkit-driver": "^2.3.0",
        "friends-of-behat/mink-extension": "^2.7.5",
        "symfony/browser-kit": "^7.4.8",
        "symfony/http-client": "^7.4.8",
        "symfony/css-selector": "^7.4.8",
        "symfony/dom-crawler": "^7.4.8",
        "symfony/dotenv": "^7.4.8",
        "symfony/mime": "^7.4.8"
    },
    "config": {
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "Erpify\\Tests\\Behat\\": "../../tests/Behat/"
        }
    }
}
