<?xml version="1.0"?>
<ruleset name="Coding Standards"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/squizlabs/PHP_CodeSniffer/master/phpcs.xsd">
    <description>PHP_CodeSniffer configuration</description>

    <!-- Coding Standard -->
    <!-- Use PSR-12 Extended Coding Style Guide -->
    <rule ref="PSR12"/>

    <!-- Files and Directories -->
    <!-- Include directories to check -->
    <file>../../bin</file>
    <file>../../config</file>
    <file>../../features</file>
    <file>../../public</file>
    <file>../../src</file>
    <file>../../tests</file>
    <file>../../tools</file>

    <!-- Exclude directories -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/var/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>

    <!-- Rules Configuration -->
    <!-- Set line length limit to 120 characters (matching PHP CS Fixer and PHP Insights config) -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="160"/>
            <property name="ignoreComments" value="false"/>
        </properties>
    </rule>

    <!-- Allow short array syntax (PSR-12 compatible) -->
    <rule ref="Generic.Arrays.DisallowLongArraySyntax"/>

    <!-- Sniff Exclusions -->

    <!-- Report Configuration -->
    <!-- Show colors in output -->
    <arg name="colors"/>
    <arg name="basepath" value="../../"/>
    <arg name="cache" value="../../var/cache/.phpcs-cache"/>
    <arg name="extensions" value="php"/>
</ruleset>
