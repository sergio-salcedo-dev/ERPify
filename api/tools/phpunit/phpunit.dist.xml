<?xml version="1.0" encoding="UTF-8"?>

<!-- Paths are relative to this file's directory (api/tools/phpunit/). -->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="../../vendor/phpunit/phpunit/phpunit.xsd"
         colors="true"
         failOnDeprecation="true"
         failOnNotice="true"
         failOnWarning="true"
         displayDetailsOnTestsThatTriggerDeprecations="true"
         displayDetailsOnPhpunitDeprecations="true"
         bootstrap="bootstrap.php"
         cacheDirectory="../../var/cache/phpunit"
>
    <php>
        <ini name="display_errors" value="1" />
        <ini name="error_reporting" value="-1" />
        <server name="APP_ENV" value="test" force="true" />
        <server name="SHELL_VERBOSITY" value="-1" />
        <server name="MERCURE_URL" value="http://127.0.0.1/.well-known/mercure" force="true" />
        <server name="MERCURE_PUBLIC_URL" value="https://localhost/.well-known/mercure" force="true" />
        <server name="MERCURE_JWT_SECRET" value="!ChangeThisMercureHubJWTSecretKey!" force="true" />
        <server name="OBJECT_STORAGE_LOCAL_PATH" value="/tmp/erpify-object-storage-test" force="true" />
    </php>

    <testsuites>
        <testsuite name="Project Test Suite">
            <directory>../../tests</directory>
        </testsuite>
    </testsuites>

    <source ignoreSuppressionOfDeprecations="true"
            ignoreIndirectDeprecations="false"
            restrictNotices="true"
            restrictWarnings="true"
    >
        <include>
            <directory>../../src</directory>
        </include>

        <deprecationTrigger>
            <function>trigger_deprecation</function>
        </deprecationTrigger>
    </source>

    <extensions>
    </extensions>
</phpunit>
