{
    "symbol-whitelist": [
        "Doctrine\\Bundle\\FixturesBundle\\DoctrineFixturesBundle",
        "Fidry\\AliceDataFixtures\\Bridge\\Symfony\\FidryAliceDataFixturesBundle",
        "Hautelook\\AliceBundle\\HautelookAliceBundle",
        "Nelmio\\Alice\\Bridge\\Symfony\\NelmioAliceBundle",
        "null",
        "true",
        "false",
        "static",
        "self",
        "parent",
        "array",
        "string",
        "int",
        "float",
        "bool",
        "iterable",
        "callable",
        "void",
        "object",
        "mixed",
        "resource",
        "never",
        "readonly",
        "enum"
    ],
    "php-core-extensions": [
        "Core",
        "date",
        "json",
        "hash",
        "pcre",
        "Phar",
        "Reflection",
        "SPL",
        "random",
        "standard",
        "curl",
        "mbstring",
        "iconv",
        "ctype",
        "pdo",
        "pdo_pgsql",
        "apcu",
        "xml"
    ],
    "scan-files": [
        "bin/console",
        "config/bundles.php",
        "config/bootstrap.php",
        "public/index.php"
    ]
}
