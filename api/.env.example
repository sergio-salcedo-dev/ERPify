# ERPify — template for the Symfony / Docker API (`api/`).
# Copy into place (tracked as `api/.env` is usually local-only):
#
#   cp .env.example api/.env
#
# Symfony: https://symfony.com/doc/current/configuration.html
# Docker Compose reads `api/.env` for `${VAR}` substitution in compose files.
# Default stack: FrankenPHP on host 80/443 + PWA (see root compose.yaml). For API on host :8000 only: `make api-up-http`.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Non-HTTP URL generation (align with SERVER_NAME / HTTPS in compose)
DEFAULT_URI=https://localhost
###< symfony/routing ###

###> nelmio/cors-bundle ###
# Comma-separated browser origins allowed to call the API (no wildcards). Must include the PWA origin (scheme + host + port).
# Include http://127.0.0.1:3000 (and :3000 on localhost) when running Playwright against `next dev` while the API is on Docker.
# Same-origin Docker dev: https://localhost (and http). Production: exact public origins, e.g. https://app.example.com
CORS_ALLOW_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000,https://localhost,https://127.0.0.1
###< nelmio/cors-bundle ###

###> docker/xdebug ###
# compose.override.yaml passes this to the php service (${XDEBUG_MODE:-off}).
# From repo root: make xdebug-enable / make xdebug-disable
XDEBUG_MODE=off
# PhpStorm: name of the entry under Settings | PHP | Servers (default dev).
# PHP_IDE_SERVER_NAME=dev
###< docker/xdebug ###

###> doctrine/doctrine-bundle ###
# After `composer require symfony/orm-pack`, uncomment (matches compose defaults).
# DATABASE_URL="postgresql://app:!ChangeMe!@database:5432/app?serverVersion=15&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# Doctrine transport: queue_name `async` is set in config/packages/messenger.yaml (options).
# auto_setup=0 expects migrations to create `messenger_messages` (see Version20260405120000).
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
# Dev: null transport. Production: smtp, SendGrid bridge, etc.
MAILER_DSN=null://null
MAILER_FROM=noreply@erpify.local
###< symfony/mailer ###

###> erpify/domain-events ###
# Recipient for bank created/updated notifications (async email handler).
DEFAULT_NOTIFICATION_EMAIL=sergio.salcedo.dev@gmail.com
###< erpify/domain-events ###

###> erpify/media ###
# Optional: absolute base for logoUrl in JSON (e.g. https://api.example.com). Leave empty to use the current request host.
# Also used for storedObjectUrl (Flysystem-backed bank attachments): {base}/api/v1/stored-objects/{hash}
MEDIA_PUBLIC_BASE_URL=
###< erpify/media ###

###> erpify/object-storage ###
# Local Flysystem root for ObjectStoragePort (bank stored_object, future aggregates). See docs/object-storage.md for production.
#
# Production checklist:
# - Set to an absolute path on a PERSISTENT volume (Docker named volume, EBS, NFS, etc.).
# - Ensure the PHP process can read/write that directory.
# - Back up this directory with PostgreSQL; restore both together.
#
# Default when unset: %kernel.project_dir%/var/storage/objects (see config/packages/flysystem.yaml).
# OBJECT_STORAGE_LOCAL_PATH=/var/lib/erpify/object-storage
###< erpify/object-storage ###

###> symfony/mercure-bundle ###
# Docker Compose usually overrides these on the php service (see repo root compose.yaml).
# MERCURE_JWT_SECRET: run `openssl rand -hex 32` per environment; match CADDY_MERCURE_JWT_SECRET.
# Never commit production secrets. See docs/mercure-production-deployment.md.
MERCURE_URL=http://localhost/.well-known/mercure
MERCURE_PUBLIC_URL=https://localhost/.well-known/mercure
MERCURE_JWT_SECRET=!ChangeThisMercureHubJWTSecretKey!
###< symfony/mercure-bundle ###
