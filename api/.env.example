# ERPify — template for the Symfony / Docker API (`api/`).
# Copy into place (tracked as `api/.env` is usually local-only):
#
#   cp .env.example api/.env
#
# Symfony: https://symfony.com/doc/current/configuration.html
# Docker Compose reads `api/.env` for `${VAR}` substitution in compose files.
# Default stack: FrankenPHP on host 80/443 + PWA (see root compose.yaml). For API on host :8000 only: `make api-up-http`.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Non-HTTP URL generation (align with SERVER_NAME / HTTPS in compose)
DEFAULT_URI=https://localhost
###< symfony/routing ###

###> nelmio/cors-bundle ###
# Comma-separated browser origins allowed to call the API (no wildcards). Must include the PWA origin (scheme + host + port).
# Include http://127.0.0.1:3000 (and :3000 on localhost) when running Playwright against `next dev` while the API is on Docker.
# Same-origin Docker dev: https://localhost (and http). Production: exact public origins, e.g. https://app.example.com
CORS_ALLOW_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000,https://localhost,https://127.0.0.1
###< nelmio/cors-bundle ###

###> docker/xdebug ###
# compose.override.yaml passes this to the php service (${XDEBUG_MODE:-off}).
# From repo root: make xdebug-enable / make xdebug-disable
XDEBUG_MODE=off
# PhpStorm: name of the entry under Settings | PHP | Servers (default dev).
# PHP_IDE_SERVER_NAME=dev
###< docker/xdebug ###

###> doctrine/doctrine-bundle ###
# After `composer require symfony/orm-pack`, uncomment (matches compose defaults).
# DATABASE_URL="postgresql://app:!ChangeMe!@database:5432/app?serverVersion=15&charset=utf8"
###< doctrine/doctrine-bundle ###
