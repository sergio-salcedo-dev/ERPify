# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

XDEBUG_MODE=develop,debug
PHP_IDE_SERVER_NAME=dev

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://erpify_user:erpify_password@database:5432/erpify_db?serverVersion=18&charset=utf8"
###< doctrine/doctrine-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000,https://localhost,https://127.0.0.1
###< nelmio/cors-bundle ###

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=null://null
MAILER_FROM=noreply@erpify.local
###< symfony/mailer ###

###> erpify/domain-events ###
BANK_NOTIFICATION_EMAIL=sergio.salcedo.dev@gmail.com
###< erpify/domain-events ###

###> symfony/mercure-bundle ###
# See https://symfony.com/doc/current/mercure.html#configuration
# Docker Compose overrides these on the php service (see repo root compose.yaml).
# Full secret generation + production checklist: docs/mercure-production-deployment.md
# The URL Symfony uses to publish (often internal, e.g. http://php/.well-known/mercure).
MERCURE_URL=http://localhost/.well-known/mercure
# Browser-facing hub URL (FrankenPHP/Caddy on the same host as the PWA in the default stack).
MERCURE_PUBLIC_URL=https://localhost/.well-known/mercure
# MERCURE_JWT_SECRET: shared HMAC key so Symfony can sign publisher/subscriber JWTs the hub trusts.
# Generate a NEW random value for each environment (never reuse dev in prod):
#   openssl rand -hex 32
# Set the SAME value as Caddy/Compose CADDY_MERCURE_JWT_SECRET (publisher/subscriber keys).
# Do not commit real production values; use a secret manager or CI-injected env only.
MERCURE_JWT_SECRET=!ChangeThisMercureHubJWTSecretKey!
###< symfony/mercure-bundle ###
