# define your env variables for the test env here
KERNEL_CLASS='Erpify\Kernel'
APP_SECRET='$ecretf0rt3st'

# Dedicated test database — fully isolated from the dev runtime so the
# behat fixtures context can DROP/CREATE WITH TEMPLATE without ever
# touching the dev DB.
DATABASE_URL="postgresql://erpify_user:erpify_password@database:5432/erpify_db_test?serverVersion=18&charset=utf8"

MERCURE_URL=http://127.0.0.1/.well-known/mercure
MERCURE_PUBLIC_URL=https://localhost/.well-known/mercure
MERCURE_JWT_SECRET=!ChangeThisMercureHubJWTSecretKey!

MEDIA_PUBLIC_BASE_URL=

# Overridden by phpunit.dist.xml for isolation; default for other test runs:
OBJECT_STORAGE_LOCAL_PATH=/tmp/erpify-object-storage-test
