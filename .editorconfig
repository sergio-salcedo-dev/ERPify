# https://editorconfig.org — monorepo root (api/, pwa/, and repo tooling)
root = true

[*]
charset = utf-8
insert_final_newline = true
end_of_line = lf
indent_style = space
indent_size = 2

[api/**]
indent_size = 4

[Makefile]
indent_style = tab

[.devcontainer/**]
indent_size = 2

[{compose.yaml,compose.*.yaml,.github/**/*.yaml}]
indent_size = 2

[**/{Dockerfile,Caddyfile,*.sh}]
indent_style = tab

[**.md]
indent_size = unset
indent_style = unset
