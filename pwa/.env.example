# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Symfony API (ERPify) ---
# Browser: base URL for JSON (paths like /api/v1/health). Docker full stack: same origin as the page.
# Default image build uses https://localhost (see root compose.yaml build args).
NEXT_PUBLIC_SYMFONY_API_BASE_URL=https://localhost

# Server-side only (SSR / RSC). Docker full stack (pwa container): http://php:80
# Local dev against API on host :8000: http://localhost:8000
SYMFONY_INTERNAL_URL=http://php:80

# --- Playwright E2E (playwright.config.ts) ---
# Parallel workers. Leave unset or empty for Playwright default locally; CI uses 1 unless set.
# PW_WORKERS=4
# When using `webServer`, Symfony URLs below override pwa/.env.local for the dev server process:
# PLAYWRIGHT_SYMFONY_API_BASE_URL=https://localhost
# PLAYWRIGHT_SYMFONY_INTERNAL_URL=https://localhost
