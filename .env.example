# ERPify — template for the Symfony / Docker API (`api/`).
# Copy into place (tracked as `api/.env` is usually local-only):
#
#   cp .env.example api/.env
#
# Symfony: https://symfony.com/doc/current/configuration.html
# Docker Compose reads `api/.env` for `${VAR}` substitution in compose files.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Non-HTTP URL generation (align with SERVER_NAME / HTTPS in compose)
DEFAULT_URI=https://localhost
###< symfony/routing ###

###> docker/xdebug ###
# compose.override.yaml passes this to the php service (${XDEBUG_MODE:-off}).
# From repo root: make xdebug-enable / make xdebug-disable
XDEBUG_MODE=off
# PhpStorm: name of the entry under Settings | PHP | Servers (default dev).
# PHP_IDE_SERVER_NAME=dev
###< docker/xdebug ###

###> doctrine/doctrine-bundle ###
# After `composer require symfony/orm-pack`, uncomment (matches compose defaults).
# DATABASE_URL="postgresql://app:!ChangeMe!@database:5432/app?serverVersion=15&charset=utf8"
###< doctrine/doctrine-bundle ###
